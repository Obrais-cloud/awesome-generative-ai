# Content Generation Machine - Environment Variables
# Copy this file to .env and fill in your values

# === Niche Configuration ===
# The topic/industry to focus content on (e.g., "marketing", "AI", "fitness")
CONTENT_NICHE=marketing

# === Scrape Creators API ===
# Sign up at https://scrapecreators.com to get your API key
SCRAPE_CREATORS_API_KEY=your_api_key_here

# === Target Creators ===
# Comma-separated list of creator usernames/URLs to monitor
TARGET_CREATORS_INSTAGRAM=creator1,creator2,creator3
TARGET_CREATORS_TWITTER=creator1,creator2,creator3
TARGET_CREATORS_LINKEDIN=creator1,creator2,creator3
TARGET_CREATORS_TIKTOK=creator1,creator2,creator3

# === Content Generation ===
# Anthropic API key for content generation with Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Dashboard ===
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050

# === Optional: Google Integration ===
# For exporting content to Google Sheets/Slides
# GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_TOKEN_FILE=token.json
