# Content Machine — Vercel Environment Variables
# Add these in your Vercel project settings (Settings > Environment Variables)

# The niche/industry to focus content on
CONTENT_NICHE=marketing

# Anthropic API key for AI-powered content generation (optional)
# Without this, the app falls back to template-based generation
ANTHROPIC_API_KEY=

# Scrape Creators API key (optional, uses sample data if not set)
SCRAPE_CREATORS_API_KEY=
